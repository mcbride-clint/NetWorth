@inherits LayoutComponentBase
@using NetWorth.Services
@inject StatementService StatementService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IDialogService DialogService

<MudLayout>
    <MudAppBar>
        @(string.IsNullOrWhiteSpace(StatementService.Current.Household.LastName)
            ? "Net Worth Tracker"
            : $"{StatementService.Current.Household.LastName} Family Net Worth")
        <MudSpacer />
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudNavLink Href="/" Match="NavLinkMatch.All">Dashboard</MudNavLink>
            <MudNavLink Href="/household" Match="NavLinkMatch.Prefix">Household Info</MudNavLink>
            <MudNavLink Href="/accounts" Match="NavLinkMatch.Prefix">Accounts</MudNavLink>
            <MudNavLink Href="/debt-payoff" Match="NavLinkMatch.Prefix">Debt Payoff</MudNavLink>
            <MudNavLink Href="/footnotes" Match="NavLinkMatch.Prefix">Footnotes</MudNavLink>
            <MudNavLink Href="/statements" Match="NavLinkMatch.Prefix">Year Statements</MudNavLink>
            <MudMenu Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <MudMenuItem OnClick="ExportStatement" Icon="@Icons.Material.Filled.Upload">Export Statement (.json)</MudMenuItem>
                <MudMenuItem OnClick="ImportStatement" Icon="@Icons.Material.Filled.Download">Import Statement (.json)</MudMenuItem>
                <MudDivider />
                <MudMenuItem OnClick="LoadDemo" Icon="@Icons.Material.Filled.Science">Load Demo Statement</MudMenuItem>
            </MudMenu>
        </MudStack>
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<MudThemeProvider IsDarkMode="true" />
<MudDialogProvider />
<MudSnackbarProvider />

@code {
    private async Task ExportStatement()
    {
        await StatementService.ExportStatementToFileAsync();
        Snackbar.Add("Statement exported.", Severity.Success);
    }

    private async Task ImportStatement()
    {
        var result = await StatementService.ImportStatementFromFileAsync();
        if (result)
        {
            Snackbar.Add("Statement imported! Review and click Save to persist.", Severity.Success);
            NavigationManager.NavigateTo("/household");
        }
        else
        {
            Snackbar.Add("Failed to import statement: Invalid file.", Severity.Error);
        }
    }

    private async Task LoadDemo()
    {
        if (StatementService.Current.YearSummaries.Any())
        {
            var confirmed = await DialogService.ShowMessageBox(
                "Load Demo Statement",
                "This will replace your current unsaved data with the demo. Your saved data in IndexedDB will not be affected. Continue?",
                "Load Demo", "Cancel");

            if (!confirmed.GetValueOrDefault()) return;
        }

        StatementService.LoadDemo();
        Snackbar.Add("Demo statement loaded. Click Save to persist it.", Severity.Info);
        NavigationManager.NavigateTo("/");
    }
}
