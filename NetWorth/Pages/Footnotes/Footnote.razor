@page "/footnotes"
@using NetWorth.Domain
@using NetWorth.Services

<h3>Footnotes</h3>

<MudPaper Class="pa-4 mud-height-full">
    <MudTabs Position="Position.Left">
        <MudTabPanel Text="Life Insurance Plans">
            <LifeInsurancePlans Plans="StatementService.Current.Footnote.LifeInsurancePlans"
                                PlansChanged="@((List<LifeInsurancePlan> plans) => StatementService.Current.Footnote.LifeInsurancePlans = plans)" />
        </MudTabPanel>
        <MudTabPanel Text="College Savings Accounts">
            <CollegeSavingsAccounts Accounts="StatementService.Current.Footnote.CollegeSavingsAccounts"
                                    AccountsChanged="@((List<CollegeSavingsAccount> accounts) => StatementService.Current.Footnote.CollegeSavingsAccounts = accounts)" />
        </MudTabPanel>
        <MudTabPanel Text="Real Estate Details">
            <MudTextField Label="Real Estate Details" @bind-Value="StatementService.Current.Footnote.RealEstateDetails" FullWidth="true" />
        </MudTabPanel>
    </MudTabs>
</MudPaper>

<MudAppBar Bottom Fixed>
    <MudButton ButtonType="ButtonType.Button" Variant="Variant.Outlined" Color="Color.Secondary" Class="ml-auto" OnClick="ResetFootnotes">Reset</MudButton>
    <MudSpacer />
    <MudButton ButtonType="ButtonType.Button" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" OnClick="SaveFootnotes">Save</MudButton>
</MudAppBar>

@code {
    [Inject]
    private IJSRuntime JsRuntime { get; set; }

    [Inject] protected StatementService StatementService { get; set; }

    private async Task SaveFootnotes()
    {
        await StatementService.SaveAsync();
        await JsRuntime.InvokeVoidAsync("alert", "Footnotes saved successfully!");
    }

    private async Task ResetFootnotes()
    {
        await StatementService.ResetAsync();
        await JsRuntime.InvokeVoidAsync("alert", "Footnotes reset to last saved state.");
    }
}