@page "/household"

@using NetWorth.Domain
@using NetWorth.Services

@inherits SaveResetPageBase<Household>

@inject NetWorth.Services.StatementService StatementService

<MudText Typo="Typo.h5" Class="mb-4">Household Info</MudText>

<EditForm Model="@StatementService.Current.Household">
    <DataAnnotationsValidator />

    <MudCard Class="mb-6">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Personal Information</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField Label="First Name"
                                  @bind-Value="StatementService.Current.Household.FirstName"
                                  @bind-Value:after="StatementService.MarkDirty"
                                  For="@(() => StatementService.Current.Household.FirstName)"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Label="Spouse First Name"
                                  @bind-Value="StatementService.Current.Household.SpouseFirstName"
                                  @bind-Value:after="StatementService.MarkDirty"
                                  For="@(() => StatementService.Current.Household.SpouseFirstName)"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Label="Last Name"
                                  @bind-Value="StatementService.Current.Household.LastName"
                                  @bind-Value:after="StatementService.MarkDirty"
                                  For="@(() => StatementService.Current.Household.LastName)"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6" />
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="Date of Birth"
                                   @bind-Date="StatementService.Current.Household.DateOfBirth"
                                   @bind-Date:after="StatementService.MarkDirty"
                                   For="@(() => StatementService.Current.Household.DateOfBirth)"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="Spouse Date of Birth"
                                   @bind-Date="StatementService.Current.Household.SpouseDateOfBirth"
                                   @bind-Date:after="StatementService.MarkDirty"
                                   For="@(() => StatementService.Current.Household.SpouseDateOfBirth)"
                                   Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

</EditForm>

<MudText Typo="Typo.h5" Class="mb-4">Footnotes</MudText>

<MudCard Class="mb-6">
    <MudCardContent>
        <MudTabs>
            <MudTabPanel Text="Life Insurance Plans">
                <LifeInsurancePlans Plans="StatementService.Current.Footnote.LifeInsurancePlans"
                                    PlansChanged="@((List<LifeInsurancePlan> plans) => { StatementService.Current.Footnote.LifeInsurancePlans = plans; StatementService.MarkDirty(); })" />
            </MudTabPanel>
            <MudTabPanel Text="College Savings Accounts">
                <CollegeSavingsAccounts Accounts="StatementService.Current.Footnote.CollegeSavingsAccounts"
                                        AccountsChanged="@((List<CollegeSavingsAccount> accounts) => { StatementService.Current.Footnote.CollegeSavingsAccounts = accounts; StatementService.MarkDirty(); })" />
            </MudTabPanel>
            <MudTabPanel Text="Real Estate Details">
                <MudTextField Label="Real Estate Details"
                              @bind-Value="StatementService.Current.Footnote.RealEstateDetails"
                              @bind-Value:after="StatementService.MarkDirty"
                              FullWidth="true"
                              Lines="6"
                              Variant="Variant.Outlined" />
            </MudTabPanel>
        </MudTabs>
    </MudCardContent>
</MudCard>

<SaveResetFooter OnSave="Save" OnReset="Reset" />
