@page "/household"

@using NetWorth.Domain
@using NetWorth.Services

<h3>Household Info</h3>

<EditForm Model="@StatementService.Current.Household">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12" sm="7">
            <MudCard>
                <MudCardContent>
                    <MudTextField Label="First Name"
                                  @bind-Value="StatementService.Current.Household.FirstName"
                                  @bind-Value:after="StatementService.MarkDirty"
                                  For="@(() => StatementService.Current.Household.FirstName)" />
                    <MudTextField Label="Spouse First Name" Class="mt-3"
                                  @bind-Value="StatementService.Current.Household.SpouseFirstName"
                                  @bind-Value:after="StatementService.MarkDirty"
                                  For="@(() => StatementService.Current.Household.SpouseFirstName)" />
                    <MudTextField Label="Last Name" HelperText="Max. 8 characters" Class="mt-3"
                                  @bind-Value="StatementService.Current.Household.LastName"
                                  @bind-Value:after="StatementService.MarkDirty"
                                  For="@(() => StatementService.Current.Household.LastName)" />
                    <MudDatePicker Label="Date Of Birth" Class="mt-3"
                                   @bind-Date="StatementService.Current.Household.DateOfBirth"
                                   @bind-Date:after="StatementService.MarkDirty"
                                   For="@(() => StatementService.Current.Household.DateOfBirth)" />
                    <MudDatePicker Label="Spouse Date Of Birth" Class="mt-3"
                                   @bind-Date="StatementService.Current.Household.SpouseDateOfBirth"
                                   @bind-Date:after="StatementService.MarkDirty"
                                   For="@(() => StatementService.Current.Household.SpouseDateOfBirth)" />
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="5">
            <MudPaper Class="pa-4 mud-height-full">
                <MudText Typo="Typo.subtitle2">Validation Summary</MudText>
                <MudText Color="@Color.Error">
                    <ValidationSummary />
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12">
            <MudText Typo="Typo.body2" Align="Align.Center">
                Fill out the form correctly to see the success message.
            </MudText>
        </MudItem>
    </MudGrid>
</EditForm>

@inherits SaveResetPageBase<Household>

<SaveResetFooter OnSave="Save" OnReset="Reset" />

@inject NetWorth.Services.StatementService StatementService
