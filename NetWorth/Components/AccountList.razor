<MudDataGrid T="Account" Items="Items" ReadOnly="true"
             Bordered="true" Elevation="0" Dense="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">@Class.Category</MudText>
        <MudSpacer />
    </ToolBarContent>
    <Columns>
        <TemplateColumn Title="Account" IsEditable="false" CellStyle="min-width:200px">
            <CellTemplate>
                @if (!string.IsNullOrWhiteSpace(context.Item.DefinitionId))
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.body2">@context.Item.Name</MudText>
                        <MudTooltip Text="View account detail">
                            <MudIconButton Icon="@Icons.Material.Outlined.OpenInNew"
                                           Size="Size.Small" Color="Color.Default"
                                           Href="@($"/accounts/{context.Item.DefinitionId}")" />
                        </MudTooltip>
                    </MudStack>
                }
                else
                {
                    <MudText Typo="Typo.body2">@context.Item.Name</MudText>
                }
            </CellTemplate>
            <FooterTemplate>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.Add" OnClick="OpenAddPicker">Add</MudButton>
            </FooterTemplate>
        </TemplateColumn>
        <PropertyColumn Format="C" Property="x => x.Total" Title="Total" IsEditable="false">
            <FooterTemplate>
                <MudText Typo="Typo.body1">@Items.Sum(i => i.Total).ToString("C")</MudText>
            </FooterTemplate>
        </PropertyColumn>
        <TemplateColumn Title="YoY Delta" IsEditable="false" Hidden="@(PriorYearItems == null)">
            <CellTemplate>
                @{
                    var prior = PriorYearItems?.FirstOrDefault(p => p.Name == context.Item.Name);
                    var delta = prior != null ? context.Item.Total - prior.Total : (double?)null;
                }
                @if (delta.HasValue)
                {
                    <MudText Color="@(delta.Value >= 0 ? Color.Success : Color.Error)" Typo="Typo.body2">
                        @(delta.Value >= 0 ? "+" : "")@delta.Value.ToString("C0")
                    </MudText>
                }
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Context="item" IsEditable="false" Title="">
            <CellTemplate>
                <MudStack Row="true" Spacing="0">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small"
                                   OnClick="() => OpenEditDrawer(item.Item)" Title="Edit" />
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" Size="Size.Small"
                                   OnClick="() => RemoveRow(item.Item)" Title="Remove row" />
                </MudStack>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@* Definition picker popover *@
<MudPopover Open="@pickerOpen" AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft"
            Class="pa-3" Style="max-width:380px; max-height:480px; overflow-y:auto">
    <MudStack Spacing="1">
        <MudText Typo="Typo.subtitle2" Class="mb-1">Select a defined account</MudText>
        @foreach (var def in AvailableDefinitions)
        {
            <MudButton FullWidth="true" Variant="Variant.Text" OnClick="() => AddFromDefinition(def)"
                       Style="justify-content:flex-start">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@OwnerIcon(def.Owner)" Size="Size.Small" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2">@def.Name</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@def.Type</MudText>
                    </MudStack>
                </MudStack>
            </MudButton>
        }
        @if (!AvailableDefinitions.Any())
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">All defined accounts are already added.</MudText>
        }
        <MudDivider Class="my-1" />
        <MudButton FullWidth="true" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="AddCustomRow">Add custom (no definition)</MudButton>
        <MudButton FullWidth="true" Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.LibraryAdd"
                   Href="accounts" Color="Color.Primary">Manage account catalog</MudButton>
        <MudButton FullWidth="true" Variant="Variant.Text" OnClick="() => pickerOpen = false">Cancel</MudButton>
    </MudStack>
</MudPopover>

@* Edit drawer *@
<MudDrawer @bind-Open="drawerOpen" Anchor="Anchor.Right" Variant="DrawerVariant.Temporary" Width="340px">
    @if (editingAccount != null)
    {
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">@(string.IsNullOrWhiteSpace(editingAccount.Name) ? "New Account" : editingAccount.Name)</MudText>
        </MudDrawerHeader>
        <MudStack Class="pa-4" Spacing="3">
            @if (string.IsNullOrWhiteSpace(editingAccount.DefinitionId))
            {
                <MudTextField @bind-Value="editingAccount.Name" Label="Account Name" Variant="Variant.Outlined" />
                <MudAutocomplete T="string?" @bind-Value="editingAccount.Type" Label="Type" Variant="Variant.Outlined"
                                 CoerceValue="true" SearchFunc="GetItems" />
            }
            <MudNumericField @bind-Value="editingAccount.Balance" Label="@(isSingleMember ? "Balance" : "Primary Balance")"
                             Format="C" HideSpinButtons="true" Variant="Variant.Outlined" />
            @if (!isSingleMember)
            {
                <MudNumericField @bind-Value="editingAccount.SpouseBalance" Label="Spouse Balance"
                                 Format="C" HideSpinButtons="true" Variant="Variant.Outlined" />
                <MudNumericField @bind-Value="editingAccount.JointBalance" Label="Joint Balance"
                                 Format="C" HideSpinButtons="true" Variant="Variant.Outlined" />
            }
            @if (ShowContribution)
            {
                <MudNumericField @bind-Value="editingAccount.AnnualContribution" Label="Annual Contribution"
                                 Format="C0" HideSpinButtons="true" Variant="Variant.Outlined" />
            }
            @if (ShowInterestRate)
            {
                var defRate = Definitions?.FirstOrDefault(d => d.Id == editingAccount.DefinitionId)?.InterestRate;
                @if (defRate.HasValue)
                {
                    <MudTextField Value="@defRate.Value.ToString("P2")" Label="Interest Rate" Variant="Variant.Outlined" ReadOnly="true" />
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Interest rate is set in the <MudLink Href="@($"/accounts/{editingAccount.DefinitionId}")" Color="Color.Primary">Account Catalog</MudLink>.
                    </MudText>
                }
            }
            <MudTextField @bind-Value="editingAccount.Notes" Label="Notes" Variant="Variant.Outlined" Lines="2" />
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SaveDrawer">Save</MudButton>
                <MudButton Variant="Variant.Outlined" FullWidth="true" OnClick="CancelDrawer">Cancel</MudButton>
            </MudStack>
        </MudStack>
    }
</MudDrawer>

@using NetWorth.Services
@code {
    [Parameter] public List<Account> Items { get; set; } = new();
    [Parameter] public AssetClass Class { get; set; }
    [Parameter] public List<Account>? PriorYearItems { get; set; }
    [Parameter] public bool ShowContribution { get; set; } = false;
    [Parameter] public bool ShowInterestRate { get; set; } = false;
    [Parameter] public List<AccountDefinition>? Definitions { get; set; }

    [Parameter] public EventCallback OnValueChange { get; set; }
    [Inject] public StatementService StatementService { get; set; }
    [Inject] public ISnackbar Snackbar { get; set; }

    private bool isSingleMember = false;
    private bool pickerOpen = false;

    private bool drawerOpen = false;
    private Account? editingAccount = null;
    private Account editSnapshot = new();

    protected override void OnInitialized()
    {
        isSingleMember = string.IsNullOrWhiteSpace(StatementService.Current.Household.SpouseFirstName);
        base.OnInitialized();
    }

    private IEnumerable<AccountDefinition> AvailableDefinitions =>
        (Definitions ?? [])
        .Where(d => d.IsActive && !Items.Any(i => i.DefinitionId == d.Id));

    private Task<IEnumerable<string?>> GetItems(string searchText) =>
        Task.FromResult(Class.Presets.AsEnumerable<string?>());

    private void OpenAddPicker() => pickerOpen = true;

    private void OpenEditDrawer(Account item)
    {
        editingAccount = item;
        editSnapshot = new Account
        {
            DefinitionId = item.DefinitionId,
            Name = item.Name,
            Type = item.Type,
            Balance = item.Balance,
            SpouseBalance = item.SpouseBalance,
            JointBalance = item.JointBalance,
            Notes = item.Notes,
            AnnualContribution = item.AnnualContribution,
        };
        drawerOpen = true;
    }

    private async Task SaveDrawer()
    {
        drawerOpen = false;
        await OnValueChange.InvokeAsync();
    }

    private void CancelDrawer()
    {
        if (editingAccount != null)
        {
            editingAccount.Name = editSnapshot.Name;
            editingAccount.Type = editSnapshot.Type;
            editingAccount.Balance = editSnapshot.Balance;
            editingAccount.SpouseBalance = editSnapshot.SpouseBalance;
            editingAccount.JointBalance = editSnapshot.JointBalance;
            editingAccount.Notes = editSnapshot.Notes;
            editingAccount.AnnualContribution = editSnapshot.AnnualContribution;
        }
        drawerOpen = false;
    }

    private async Task AddFromDefinition(AccountDefinition def)
    {
        pickerOpen = false;
        Items.Add(new Account
        {
            DefinitionId = def.Id,
            Name = def.Name,
            Type = def.Type,
        });
        await OnValueChange.InvokeAsync();
    }

    private async Task AddCustomRow()
    {
        pickerOpen = false;
        Items.Add(new Account());
        await OnValueChange.InvokeAsync();
    }

    private async Task RemoveRow(Account item)
    {
        Items.Remove(item);
        await OnValueChange.InvokeAsync();
    }

    private static string OwnerIcon(string owner) => owner switch
    {
        "Spouse" => Icons.Material.Outlined.PersonOutline,
        "Joint"  => Icons.Material.Outlined.People,
        _        => Icons.Material.Outlined.Person,
    };
}
