@using NetWorth.Services
@implements IDisposable

@if (!hasExpenses)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        Enter <strong>Annual Expenses</strong> in a Year Statement to enable Monte Carlo simulation.
    </MudAlert>
}
else
{
    <MudCard Elevation="3" Class="mb-4">
        <MudCardContent>
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                <MudText Typo="Typo.h6">Monte Carlo Simulation</MudText>
                <MudTooltip Text="Runs thousands of randomized return sequences to show a range of possible portfolio outcomes. Each simulation applies a random annual return (drawn from a normal distribution) and subtracts your annual withdrawal. The spread of outcomes reveals how much uncertainty exists in your retirement plan.">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" Style="opacity:0.6;" />
                </MudTooltip>
            </MudStack>

            <MudGrid>
                <MudItem xs="6" sm="3">
                    <MudStack Row AlignItems="AlignItems.End" Spacing="1">
                        <MudNumericField @bind-Value="meanReturnPct" Label="Mean Annual Return (%)"
                                         Min="-10" Max="30" Step="0.5"
                                         HideSpinButtons="true" Format="0.#" Style="flex:1;" />
                        <MudTooltip Text="Expected average return per year before inflation. The S&amp;P 500 has averaged ~10% nominally and ~7% after inflation historically. Lower this to be more conservative or to model real (inflation-adjusted) returns.">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" Style="opacity:0.6;margin-bottom:8px;" />
                        </MudTooltip>
                    </MudStack>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudStack Row AlignItems="AlignItems.End" Spacing="1">
                        <MudNumericField @bind-Value="stdDevPct" Label="Volatility / Std Dev (%)"
                                         Min="1" Max="50" Step="0.5"
                                         HideSpinButtons="true" Format="0.#" Style="flex:1;" />
                        <MudTooltip Text="Standard deviation of annual returns — how much returns vary year to year. A 100% stock portfolio has historically been ~15–17%. A 60/40 stock/bond mix is ~10–12%. Higher volatility widens the gap between optimistic and pessimistic outcomes.">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" Style="opacity:0.6;margin-bottom:8px;" />
                        </MudTooltip>
                    </MudStack>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudStack Row AlignItems="AlignItems.End" Spacing="1">
                        <MudNumericField @bind-Value="years" Label="Years to Simulate"
                                         Min="5" Max="60"
                                         HideSpinButtons="true" Style="flex:1;" />
                        <MudTooltip Text="How many years your portfolio needs to last. For early retirees this is often 40–50 years. A traditional retirement at 65 typically uses 25–30 years. Longer horizons increase sequence-of-returns risk.">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" Style="opacity:0.6;margin-bottom:8px;" />
                        </MudTooltip>
                    </MudStack>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudStack Row AlignItems="AlignItems.End" Spacing="1">
                        <MudNumericField @bind-Value="simulations" Label="Simulations"
                                         Min="100" Max="5000" Step="100"
                                         HideSpinButtons="true" Style="flex:1;" />
                        <MudTooltip Text="Number of independent random scenarios to run. More simulations give a more stable and accurate success rate. 1,000 is a good balance of speed and accuracy; 5,000 gives very stable results.">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" Style="opacity:0.6;margin-bottom:8px;" />
                        </MudTooltip>
                    </MudStack>
                </MudItem>
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RunSim"
                               StartIcon="@Icons.Material.Filled.PlayArrow">
                        Run Simulation
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (result is not null)
            {
                <MudDivider Class="my-3" />

                <MudStack Row AlignItems="AlignItems.Center" Spacing="3" Class="mb-2" Wrap="Wrap.Wrap">
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                        <MudChip T="string" Color="@(result.SuccessRate >= 80 ? Color.Success : result.SuccessRate >= 60 ? Color.Warning : Color.Error)"
                                 Size="Size.Large">
                            @result.SuccessRate.ToString("0.#")% Success Rate
                        </MudChip>
                        <MudTooltip Text="Percentage of simulations where the portfolio lasted the full period without running out of money. ≥90% is considered very safe, 80–90% is good, 60–80% is moderate risk, below 60% warrants revisiting your withdrawal amount or retirement date.">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" Style="opacity:0.6;" />
                        </MudTooltip>
                    </MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @simulations simulations · withdrawing @annualWithdrawal.ToString("C0")/yr from @startNW.ToString("C0") starting NW
                    </MudText>
                </MudStack>

                <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-1" Wrap="Wrap.Wrap">
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.caption" Style="color:#F44336;">— P10 (pessimistic)</MudText>
                        <MudTooltip Text="10th percentile: only 10% of simulations ended with a portfolio this low or lower. Represents a bad-luck sequence of returns.">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="color:#F44336;font-size:0.75rem;opacity:0.8;" />
                        </MudTooltip>
                    </MudStack>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.caption" Style="color:#2196F3;">— P50 (median)</MudText>
                        <MudTooltip Text="50th percentile: the middle outcome. Half of all simulations finished above this line, half below. A reasonable central estimate.">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="color:#2196F3;font-size:0.75rem;opacity:0.8;" />
                        </MudTooltip>
                    </MudStack>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.caption" Style="color:#4CAF50;">— P90 (optimistic)</MudText>
                        <MudTooltip Text="90th percentile: only 10% of simulations ended higher than this. Represents a favorable sequence of returns — don't plan around this outcome.">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="color:#4CAF50;font-size:0.75rem;opacity:0.8;" />
                        </MudTooltip>
                    </MudStack>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Values in thousands ($k)</MudText>
                </MudStack>

                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@series"
                          XAxisLabels="@xLabels"
                          Width="100%"
                          Height="300px"
                          ChartOptions="@chartOptions" />
            }
        </MudCardContent>
    </MudCard>
}

@code {
    [Inject] private StatementService StatementService { get; set; } = default!;
    [Inject] private MonteCarloService MonteCarloService { get; set; } = default!;

    private bool hasExpenses;
    private double startNW;
    private double annualWithdrawal;

    private double meanReturnPct = 7.0;
    private double stdDevPct = 12.0;
    private int years = 30;
    private int simulations = 1000;

    private MonteCarloResult? result;
    private List<ChartSeries> series = [];
    private string[] xLabels = [];
    private ChartOptions chartOptions = new()
    {
        YAxisFormat = "C0",
        MaxNumYAxisTicks = 5,
        ChartPalette = ["#F44336", "#2196F3", "#4CAF50"]
    };

    protected override void OnInitialized()
    {
        StatementService.StateChanged += OnStateChanged;
        LoadData();
    }

    private async void OnStateChanged()
    {
        await InvokeAsync(() => { LoadData(); StateHasChanged(); });
    }

    private void LoadData()
    {
        var latest = StatementService.Current.YearSummaries
            .OrderByDescending(s => s.Year).FirstOrDefault();
        hasExpenses = latest?.AnnualExpenses > 0;
        startNW = latest?.YearNetWorth ?? 0;
        annualWithdrawal = latest is not null ? (double)latest.AnnualExpenses : 0;
    }

    private void RunSim()
    {
        result = MonteCarloService.RunSimulation(
            startNW, annualWithdrawal,
            meanReturnPct / 100.0, stdDevPct / 100.0,
            years, simulations);

        var currentYear = DateTime.Now.Year;
        xLabels = Enumerable.Range(1, years)
            .Where(y => y % 5 == 0)
            .Select(y => (currentYear + y).ToString())
            .ToArray();

        // Build label array for every year but only show every 5th
        var allLabels = Enumerable.Range(1, years)
            .Select(y => y % 5 == 0 ? (currentYear + y).ToString() : "")
            .ToArray();

        series =
        [
            new ChartSeries { Name = "P10 (pessimistic)", Data = result.P10 },
            new ChartSeries { Name = "P50 (median)",      Data = result.P50 },
            new ChartSeries { Name = "P90 (optimistic)",  Data = result.P90 },
        ];
        xLabels = allLabels;
    }

    public void Dispose()
    {
        StatementService.StateChanged -= OnStateChanged;
    }
}
