<EditForm Model="@working" OnValidSubmit="OnValidSubmit">
    <DataAnnotationsValidator />
    <MudStack>
        <MudItem>
            <MudDatePicker Label="AsOfDate" Class="mt-3"
                           @bind-Date="working.AsOfDate" For="@(() => working.AsOfDate)" />

            <MudCard Elevation="3">
                <MudCardHeader>
                    <MudText Color="Color.Primary" Typo="Typo.h4">Assets</MudText>
                </MudCardHeader>
                <MudStack Spacing="5">
                    <AccountList Header="Cash" Items="working.CashAccounts" />
                    <AccountList Header="After Tax Investments" Items="working.AfterTaxInvestmentAccounts" />
                    <AccountList Header="Tax Deferred Investments" Items="working.TaxDeferredInvestmentAccounts" />
                    <AccountList Header="Tax Free Investments" Items="working.TaxFreeInvestmentAccounts" />
                    <AccountList Header="Business Interests" Items="working.BusinessInterests" />
                    <AccountList Header="Property" Items="working.Property" />
                </MudStack>
            </MudCard>


            <MudText Typo="Typo.h1">Liabilities</MudText>
            <MudText Typo="Typo.h2">Liabilities</MudText>
            <AccountList Items="working.Liabilities" />
            <MudText Typo="Typo.h2">Deferred Taxes</MudText>
            <AccountList Items="working.DeferredTaxes" />
        </MudItem>

        <MudItem>
            <MudButton ButtonType="ButtonType.Button"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Class="ml-auto"
                       OnClick="Undo">
                Undo All Changes
            </MudButton>
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto">Save</MudButton>
        </MudItem>
    </MudStack>
</EditForm>

@code {
    [Inject] private Statement _statement { get; set; }
    [Parameter] public int Year { get; set; }

    private YearSummary working;
    private bool success;

    protected override Task OnParametersSetAsync()
    {
        working = _statement.GetSummary(Year).Clone();

        return base.OnParametersSetAsync();
    }

    protected void Undo()
    {
        working = _statement.GetSummary(Year).Clone();
    }

    protected void OnValidSubmit(EditContext context)
    {
        success = true;
        _statement.SaveSummary(working);
    }
}
