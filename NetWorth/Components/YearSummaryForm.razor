@using NetWorth.Services

@if (working == null) { return; }

<MudStack Spacing="4">
    <MudGrid>
        <MudItem xs="12" sm="6" md="4">
            <MudNumericField @bind-Value="working.HouseholdIncome"
                             @bind-Value:after="OnIncomeChanged"
                             Label="Household Income"
                             Format="C0"
                             HideSpinButtons="true"
                             Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudNumericField @bind-Value="working.AnnualExpenses"
                             @bind-Value:after="OnIncomeChanged"
                             Label="Annual Expenses"
                             Format="C0"
                             HideSpinButtons="true"
                             Variant="Variant.Outlined" />
        </MudItem>
    </MudGrid>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-3">
        <MudTabPanel Text="Liquid Assets">
            <AccountList Class="AssetClass.Cash" Items="working.CashAccounts"
                         PriorYearItems="priorSummary?.CashAccounts"
                         Definitions="DefsFor(AssetClass.Cash)"
                         OnValueChange="OnAccountsChanged" />
        </MudTabPanel>
        <MudTabPanel Text="Investments">
            <MudStack Spacing="5">
                <AccountList Class="AssetClass.AfterTax" Items="working.AfterTaxInvestmentAccounts"
                             PriorYearItems="priorSummary?.AfterTaxInvestmentAccounts"
                             Definitions="DefsFor(AssetClass.AfterTax)"
                             ShowContribution="true"
                             OnValueChange="OnAccountsChanged" />
                <AccountList Class="AssetClass.TaxDeferred" Items="working.TaxDeferredInvestmentAccounts"
                             PriorYearItems="priorSummary?.TaxDeferredInvestmentAccounts"
                             Definitions="DefsFor(AssetClass.TaxDeferred)"
                             ShowContribution="true"
                             OnValueChange="OnAccountsChanged" />
                <AccountList Class="AssetClass.TaxFree" Items="working.TaxFreeInvestmentAccounts"
                             PriorYearItems="priorSummary?.TaxFreeInvestmentAccounts"
                             Definitions="DefsFor(AssetClass.TaxFree)"
                             ShowContribution="true"
                             OnValueChange="OnAccountsChanged" />
            </MudStack>
        </MudTabPanel>
        <MudTabPanel Text="Property & Business">
            <MudStack Spacing="5">
                <AccountList Class="AssetClass.BusinessInterests" Items="working.BusinessInterests"
                             PriorYearItems="priorSummary?.BusinessInterests"
                             Definitions="DefsFor(AssetClass.BusinessInterests)"
                             OnValueChange="OnAccountsChanged" />
                <AccountList Class="AssetClass.Property" Items="working.Property"
                             PriorYearItems="priorSummary?.Property"
                             Definitions="DefsFor(AssetClass.Property)"
                             OnValueChange="OnAccountsChanged" />
            </MudStack>
        </MudTabPanel>
        <MudTabPanel Text="Liabilities">
            <MudStack Spacing="5">
                <AccountList Class="AssetClass.Liability" Items="working.Liabilities"
                             PriorYearItems="priorSummary?.Liabilities"
                             Definitions="DefsFor(AssetClass.Liability)"
                             ShowInterestRate="true"
                             OnValueChange="OnAccountsChanged" />
                <AccountList Class="AssetClass.DeferredTax" Items="working.DeferredTaxes"
                             PriorYearItems="priorSummary?.DeferredTaxes"
                             Definitions="DefsFor(AssetClass.DeferredTax)"
                             OnValueChange="OnAccountsChanged" />
            </MudStack>
        </MudTabPanel>
    </MudTabs>
</MudStack>

@code {
    [Inject] private StatementService StatementService { get; set; }
    [Parameter] public int Year { get; set; }

    private YearSummary working;
    private YearSummary? priorSummary;

    protected override async Task OnParametersSetAsync()
    {
        await Task.Yield();
        working = StatementService.Current.GetSummary(Year);
        working.Year = Year;
        priorSummary = StatementService.Current.YearSummaries.FirstOrDefault(s => s.Year == Year - 1);
    }

    private List<AccountDefinition> DefsFor(AssetClass assetClass) =>
        StatementService.Current.AccountDefinitions
            .Where(d => d.AssetClassCategory == assetClass.Category && d.IsActive)
            .ToList();

    private void OnAccountsChanged()
    {
        StatementService.Current.SaveSummary(working);
        StatementService.MarkDirty();
        StateHasChanged();
    }

    private void OnIncomeChanged()
    {
        StatementService.Current.SaveSummary(working);
        StatementService.MarkDirty();
    }
}
