@using NetWorth.Services
<MudText Color="Color.Primary" Typo="Typo.h4">Assets</MudText>
<MudStack Spacing="5">
    <AccountList Class="AssetClass.Cash" Items="working.CashAccounts" OnValueChange="OnAccountsChanged" />
    <AccountList Class="AssetClass.AfterTax" Items="working.AfterTaxInvestmentAccounts" OnValueChange="OnAccountsChanged" />
    <AccountList Class="AssetClass.TaxDeferred" Items="working.TaxDeferredInvestmentAccounts" OnValueChange="OnAccountsChanged" />
    <AccountList Class="AssetClass.TaxFree" Items="working.TaxFreeInvestmentAccounts" OnValueChange="OnAccountsChanged" />
    <AccountList Class="AssetClass.BusinessInterests" Items="working.BusinessInterests" OnValueChange="OnAccountsChanged" />
    <AccountList Class="AssetClass.Property" Items="working.Property" OnValueChange="OnAccountsChanged" />
</MudStack>

<MudText Color="Color.Primary" Typo="Typo.h4">Liabilities</MudText>
<MudStack Spacing="5">
    <AccountList Class="AssetClass.Liability" Items="working.Liabilities" OnValueChange="OnAccountsChanged" />
</MudStack>

@code {
    [Inject] private StatementService StatementService { get; set; }
    [Parameter] public int Year { get; set; }

    private YearSummary working;

    protected override async Task OnParametersSetAsync()
    {
        await Task.Yield();
        working = StatementService.Current.GetSummary(Year);
        working.Year = Year;
    }

    private void OnAccountsChanged()
    {
        StatementService.Current.SaveSummary(working);
        StateHasChanged();
    }
}
