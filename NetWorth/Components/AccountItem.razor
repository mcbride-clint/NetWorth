<MudStack Row="true">
    <MudAutocomplete Label="Name"
                     @bind-Value="Item.Name"
                     SearchFunc="GetPredefinedOptionsAsync"
                     CoerceValue="true"
                     CoerceText="true"
                     OnInternalInputChanged="OnValueChanging"
                     OnBlur="AddToList" />
    <MudNumericField Format="C" @bind-Value="Item.Balance" Label="@(statement.Household.FirstName)" />
    <MudNumericField Format="C" @bind-Value="Item.SpouseBalance" Label="@(statement.Household.SpouseFirstName ?? "Spouse")" />
    <MudNumericField Format="C" @bind-Value="Item.JointBalance" Label="Titled Jointly" />
</MudStack>
@code {
    [Parameter] public Account Item { get; set; }
    [Parameter] public EventCallback OnChange { get; set; }

    [Inject] private Statement statement { get; set; }

    private bool readyToAdd = false;

    private async Task<IEnumerable<string?>> GetPredefinedOptionsAsync(string searchText)
    {
        return [
            "Checking Accounts",
            "Saving Accounts",
            "CDs (Certificates of Deposit)",
            "Cash",
            "Life Insurance (Cash Surrender Value)",
            "Health Savings Account",
            "Other",
            "None"
        ];
    }

    private async Task AddToList()
    {
        if (!string.IsNullOrWhiteSpace(Item.Name))
        {
            await OnChange.InvokeAsync();
        }
    }

    private void OnValueChanging(ChangeEventArgs args)
    {
        if (!string.IsNullOrWhiteSpace((string?)args.Value))
        {
            readyToAdd = true;
        }
    }
}

